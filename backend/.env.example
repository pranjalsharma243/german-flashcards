SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/flashcards
SPRING_DATASOURCE_USERNAME=flashcards
SPRING_DATASOURCE_PASSWORD=flashcards
APP_JWT_SECRET=<run: openssl rand -base64 32>
REDIS_HOST=localhost
REDIS_PORT=6379
OPENAI_API_KEY=<your-openai-key>

# Google OAuth2 — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# Backend callback URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
# Frontend origin that receives the JWT after OAuth2 success
FRONTEND_URL=http://localhost:5173
